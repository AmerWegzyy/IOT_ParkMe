# ==========================================
# PARKME ENVIRONMENT VARIABLES (Google Cloud + Firebase)
# ==========================================

# 1. Firebase / Google Cloud
# Path to your Firebase service account JSON key file.
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# 2. Edge Security (HMAC)
# The secret key used to compute the HMAC-SHA256 signature.
# This MUST match the key provisioned securely in the ESP32 NVS partition.
ESP32_HMAC_SECRET=super_secret_hmac_key_replace_me_in_production

# 3. Application Settings
ENVIRONMENT=development
PORT=8000
