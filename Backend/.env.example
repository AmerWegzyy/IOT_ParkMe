# ==========================================
# PARKME ENVIRONMENT VARIABLES
# ==========================================

# 1. PostgreSQL (Supabase)
# CRITICAL: Use the Transaction pooler connection string (usually port 6543 for Supabase)
# This prevents exhausting the database connections when scaling FastAPI workers.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# 2. Edge Security (HMAC)
# The secret key used to compute the HMAC-SHA256 signature.
# This MUST match the key provisioned securely in the ESP32 NVS partition.
ESP32_HMAC_SECRET=super_secret_hmac_key_replace_me_in_production

# 3. Application Settings
ENVIRONMENT=development
PORT=8000
