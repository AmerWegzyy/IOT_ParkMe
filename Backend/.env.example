# ==========================================
# PARKME ENVIRONMENT VARIABLES (Google Cloud + Firebase)
# ==========================================

# Local development only:
# Point this at the downloaded Firebase Admin service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Recommended for local development when using Application Default Credentials.
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_CLOCK_SKEW_SECONDS=10

# Set the same value in the backend and the ESP32 firmware before enabling
# signed hardware requests in a shared or production environment.
ESP32_HMAC_SECRET=change-me-before-production

# Application settings
ENVIRONMENT=development
PORT=8000
